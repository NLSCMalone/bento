rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper for IDs
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Helper for MenuItems
    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    // Helper for Orders
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'items', 'totalAmount', 'status', 'createdAt', 'updatedAt']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // MenuItems: Anyone can read, anyone can write (since no OAuth, protected by UI)
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isValidId(itemId) && isValidMenuItem(request.resource.data);
    }

    // Orders: Anyone can create, read (by ID), and update (status)
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow get: if true;
      allow list: if true; // In a real app we'd restrict this, but here it's simplified
      allow update: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow delete: if false;
    }

    // Settings: Anyone can read, anyone can write (setup phase)
    match /settings/admin {
      allow read: if true;
      allow write: if true;
    }
  }
}
